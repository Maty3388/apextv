<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="@color/surface" android:gravity="center_vertical"
        android:paddingHorizontal="16dp" android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="⚙️ Panel Admin"
            android:textColor="@color/primary" android:textSize="18sp" android:textStyle="bold"/>
        <TextView android:id="@+id/btnBack"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="← Volver" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:padding="8dp" android:clickable="true"/>
    </LinearLayout>

    <!-- Tabs -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
        android:background="@color/surface2" android:orientation="horizontal">
        <TextView android:id="@+id/tabUsers"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="👥 Usuarios"
            android:textSize="13sp" android:textStyle="bold" android:clickable="true"/>
        <TextView android:id="@+id/tabCredits"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="💰 Créditos"
            android:textSize="13sp" android:textStyle="bold" android:clickable="true"/>
        <TextView android:id="@+id/tabStats"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="📊 Stats"
            android:textSize="13sp" android:textStyle="bold" android:clickable="true"/>
    </LinearLayout>

    <!-- Panel Usuarios -->
    <LinearLayout android:id="@+id/panelUsers"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:visibility="visible">

        <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@color/surface" android:gravity="center_vertical"
            android:paddingHorizontal="16dp" android:orientation="horizontal">
            <EditText android:id="@+id/etSearchUser"
                android:layout_width="0dp" android:layout_height="36dp"
                android:layout_weight="1" android:hint="Buscar usuario..."
                android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
                android:background="@color/surface2" android:paddingHorizontal="12dp"
                android:textSize="13sp" android:singleLine="true"/>
            <TextView android:id="@+id/btnCreateUser"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="➕ Crear" android:textColor="@color/background"
                android:background="@color/primary" android:gravity="center"
                android:paddingHorizontal="16dp" android:layout_marginStart="8dp"
                android:textStyle="bold" android:textSize="13sp" android:clickable="true"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvUsers"
            android:layout_width="match_parent" android:layout_height="match_parent"/>
    </LinearLayout>

    <!-- Panel Créditos -->
    <LinearLayout android:id="@+id/panelCredits"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:padding="16dp" android:visibility="gone">

        <TextView android:id="@+id/tvMyCredits"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/primary" android:textSize="22sp"
            android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/tvMyRole"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Asignar créditos a revendedor"
            android:textColor="@color/text_primary" android:textSize="15sp"
            android:textStyle="bold" android:layout_marginBottom="12dp"/>

        <EditText android:id="@+id/etCreditEmail"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="Email del revendedor"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:background="@color/surface2" android:paddingHorizontal="16dp"
            android:textSize="14sp" android:layout_marginBottom="8dp"/>

        <EditText android:id="@+id/etCreditAmount"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:hint="Cantidad de créditos"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:background="@color/surface2" android:paddingHorizontal="16dp"
            android:textSize="14sp" android:inputType="number"
            android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/btnAssignCredits"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="💰 ASIGNAR CRÉDITOS" android:textColor="@color/background"
            android:background="@color/primary" android:gravity="center"
            android:textStyle="bold" android:textSize="14sp" android:clickable="true"/>
    </LinearLayout>

    <!-- Panel Stats -->
    <LinearLayout android:id="@+id/panelStats"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:padding="24dp" android:visibility="gone">

        <TextView android:id="@+id/tvStatTotal"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="18sp"
            android:layout_marginBottom="12dp"/>
        <TextView android:id="@+id/tvStatActive"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/primary" android:textSize="18sp"
            android:layout_marginBottom="12dp"/>
        <TextView android:id="@+id/tvStatDemos"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="18sp"
            android:layout_marginBottom="12dp"/>
        <TextView android:id="@+id/tvStatClients"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="18sp"/>
    </LinearLayout>

</LinearLayout>
