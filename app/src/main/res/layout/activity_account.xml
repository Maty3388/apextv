<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical"
    android:gravity="center" android:padding="32dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="👤 Mi Cuenta" android:textColor="@color/primary"
        android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="32dp"/>

    <TextView android:id="@+id/tvEmail"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/text_primary" android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <TextView android:id="@+id/tvSubEnd"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/text_secondary" android:textSize="13sp"
        android:layout_marginBottom="32dp"/>

    <Button android:id="@+id/btnPin"
        android:layout_width="220dp" android:layout_height="48dp"
        android:text="🔒 Configurar PIN" android:textColor="@color/background"
        android:backgroundTint="@color/primary" android:layout_marginBottom="12dp"
        android:focusable="true"/>

    <Button android:id="@+id/btnClose"
        android:layout_width="220dp" android:layout_height="48dp"
        android:text="← Volver" android:textColor="@color/text_secondary"
        android:backgroundTint="@color/surface2" android:layout_marginBottom="12dp"
        android:focusable="true"/>

    <Button android:id="@+id/btnLogout"
        android:layout_width="220dp" android:layout_height="48dp"
        android:text="🚪 Cerrar Sesión" android:textColor="@color/background"
        android:backgroundTint="@color/error" android:focusable="true"/>
</LinearLayout>
