<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">

    <TextureView android:id="@+id/textureView"
        android:layout_width="match_parent" android:layout_height="match_parent"/>

    <!-- Overlay de carga -->
    <LinearLayout android:id="@+id/layoutLoading"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#000000" android:orientation="vertical"
        android:gravity="center" android:visibility="gone">

        <ImageView android:id="@+id/ivLogo"
            android:layout_width="80dp" android:layout_height="80dp"
            android:scaleType="centerInside" android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/tvNumber"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/primary" android:textSize="80sp"
            android:textStyle="bold" android:fontFamily="serif"/>

        <TextView android:id="@+id/tvName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="22sp"
            android:textStyle="bold" android:layout_marginTop="8dp"/>

        <TextView android:id="@+id/tvCategory"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/primary" android:textSize="14sp"
            android:layout_marginTop="4dp" android:layout_marginBottom="28dp"/>

        <ProgressBar android:layout_width="40dp" android:layout_height="40dp"
            android:indeterminateTint="@color/primary"/>
    </LinearLayout>

    <!-- Controles bottom -->
    <LinearLayout android:id="@+id/layoutControls"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="horizontal" android:padding="16dp"
        android:gravity="center_vertical" android:visibility="gone">

        <ImageView android:id="@+id/ivControlLogo"
            android:layout_width="52dp" android:layout_height="52dp"
            android:scaleType="centerInside" android:layout_marginEnd="16dp"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvControlName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_primary" android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView android:id="@+id/tvControlCategory"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/primary" android:textSize="13sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="end">
            <TextView android:id="@+id/tvControlNumber"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:textSize="13sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="◀ ▶ Cambiar canal" android:textColor="@color/text_hint"
                android:textSize="11sp" android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
