<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:gravity="center"
    android:orientation="vertical">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="APEX" android:textColor="@color/primary"
        android:textSize="96sp" android:textStyle="bold"
        android:fontFamily="serif"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="TV" android:textColor="@color/text_primary"
        android:textSize="28sp" android:letterSpacing="0.4"/>

    <ProgressBar android:layout_width="40dp" android:layout_height="40dp"
        android:layout_marginTop="48dp"
        android:indeterminateTint="@color/primary"/>

</LinearLayout>
